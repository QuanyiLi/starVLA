#!/bin/bash
#SBATCH --job-name=starvla_wiser
#SBATCH --output=/home/lfeng/task_logs/%j.log
#SBATCH --partition=h100
#SBATCH --qos=vita
#SBATCH --ntasks-per-node=1
#SBATCH --cpus-per-task=64
#SBATCH --gpus-per-node=4
#SBATCH --nodes=3
#SBATCH --time=48:00:00
#SBATCH --mem=200G

###############################################################################
# Multi-node setup
###############################################################################
NNODES=$SLURM_NNODES            # 3
GPUS_PER_NODE=4
TOTAL_GPUS=$((NNODES * GPUS_PER_NODE))   # 12

# Resolve the master node address and port
MASTER_ADDR=$(scontrol show hostnames "$SLURM_JOB_NODELIST" | head -n 1)
MASTER_PORT=29500

export NCCL_SOCKET_IFNAME=bond0
export NCCL_IB_HCA=mlx5_2,mlx5_3
export NCCL_BLOCKING_WAIT=1
export NCCL_ASYNC_ERROR_HANDLING=1
export NCCL_TIMEOUT=3600

###############################################################################
# Paths (adjust if needed)
###############################################################################
STARVLA_ROOT=/work/vita/lanfeng/vlas/startVLA
CONFIG_YAML=${STARVLA_ROOT}/examples/wiser_panda/starvla_cotrain_wiser.yaml
DEEPSPEED_CFG=${STARVLA_ROOT}/starVLA/config/deepseeds/deepspeed_zero2.yaml

Framework_name=QwenGR00T
base_vlm=${STARVLA_ROOT}/playground/Pretrained_models/Qwen3.5-VL-9B-Instruct
DIT_TYPE="DiT-B"
freeze_module_list=''     # SOTA: fully fine-tuned

data_root_dir=/work/vita/lanfeng/vlas/vla/wiser_dataset
data_mix=wiser_panda

run_root_dir=/work/vita/lanfeng/vlas/exp_results/starVLA
run_id=starvla_wiser_panda

export WANDB_MODE=disabled

output_dir=${run_root_dir}/${run_id}
mkdir -p ${output_dir}
cp $0 ${output_dir}/

###############################################################################
# Launch training
###############################################################################
srun --kill-on-bad-exit=1 \
  accelerate launch \
    --config_file ${DEEPSPEED_CFG} \
    --main_process_ip ${MASTER_ADDR} \
    --main_process_port ${MASTER_PORT} \
    --machine_rank \$SLURM_PROCID \
    --num_machines ${NNODES} \
    --num_processes ${TOTAL_GPUS} \
    ${STARVLA_ROOT}/starVLA/training/train_starvla.py \
    --config_yaml ${CONFIG_YAML} \
    --framework.name ${Framework_name} \
    --framework.qwenvl.base_vlm ${base_vlm} \
    --framework.action_model.action_model_type ${DIT_TYPE} \
    --datasets.vla_data.data_root_dir ${data_root_dir} \
    --datasets.vla_data.data_mix ${data_mix} \
    --datasets.vla_data.per_device_batch_size 8 \
    --datasets.vla_data.lerobot_version "v3.0" \
    --datasets.vla_data.video_backend pyav \
    --trainer.freeze_modules "${freeze_module_list}" \
    --trainer.max_train_steps 100000 \
    --trainer.save_interval 5000 \
    --trainer.logging_frequency 10 \
    --trainer.eval_interval 100 \
    --trainer.learning_rate.base 3e-5 \
    --run_root_dir ${run_root_dir} \
    --run_id ${run_id} \
    --wandb_project starvla_wiser \
    --wandb_entity your_wandb_entity
