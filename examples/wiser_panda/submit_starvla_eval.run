#!/bin/bash
#SBATCH --job-name=starvla_eval
#SBATCH --output=/home/lfeng/task_logs/%j.log
#SBATCH --partition=h100
#SBATCH --qos=vita
#SBATCH --ntasks-per-node=4
#SBATCH --cpus-per-task=8
#SBATCH --gpus-per-node=4
#SBATCH --nodes=1
#SBATCH --time=12:00:00
#SBATCH --mem=100G

# ============================================================
# Evaluate trained starVLA model on all 24 subsets (train+test)
# using 4 GPUs on 1 H100 node.
# ============================================================

STARVLA_ROOT=/work/vita/lanfeng/vlas/starVLA
EVAL_SCRIPT="${STARVLA_ROOT}/examples/wiser_panda/starvla_eval.py"

# --------------- paths (edit as needed) ---------------
CHECKPOINT=/work/vita/lanfeng/vlas/exp_results/starVLA/starvla_wiser_panda/checkpoints/steps_15000_pytorch_model.pt
RESULT_DIR=/work/vita/lanfeng/vlas/starvla_eval_result
# ------------------------------------------------------

mkdir -p "${RESULT_DIR}"

# Copy this script into result dir for reproducibility
cp "$0" "${RESULT_DIR}/"

# Launch 4 processes, one per GPU, each handling 6 subsets
for GPU_ID in 0 1 2 3; do
    START=$((GPU_ID * 6))
    END=$(((GPU_ID + 1) * 6))

    CUDA_VISIBLE_DEVICES=$GPU_ID python "${EVAL_SCRIPT}" \
        --checkpoint "${CHECKPOINT}" \
        --result_dir "${RESULT_DIR}" \
        --start_subset ${START} \
        --end_subset ${END} \
        --split both \
        --eval_rounds 1 \
        --num_envs 12 \
        > "${RESULT_DIR}/gpu_${GPU_ID}.log" 2>&1 &

    echo "Launched GPU ${GPU_ID}: subsets ${START} to $((END - 1))"
done

echo "Waiting for all 4 GPU processes to finish..."
wait
echo "All rollouts complete."

# Final aggregation
echo "Running final aggregation..."
python "${EVAL_SCRIPT}" \
    --checkpoint "${CHECKPOINT}" \
    --aggregate_only \
    --result_dir "${RESULT_DIR}"

echo "Done. Results in ${RESULT_DIR}"
